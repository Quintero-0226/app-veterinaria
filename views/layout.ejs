<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Veterinaria App - <%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-base: #f7f5ef;
            --bg-surface: #fffdf8;
            --text-main: #253238;
            --text-soft: #5f6f75;
            --brand: #007f7f;
            --brand-deep: #005e5e;
            --accent: #ef6f3c;
            --line: #d7e1df;
            --shadow-soft: 0 14px 34px rgba(37, 50, 56, 0.1);
            --shadow-nav: 0 8px 28px rgba(0, 94, 94, 0.12);
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Sora', sans-serif;
            color: var(--text-main);
            background:
                radial-gradient(circle at 12% 10%, rgba(0, 127, 127, 0.14), transparent 38%),
                radial-gradient(circle at 88% 0%, rgba(239, 111, 60, 0.12), transparent 28%),
                linear-gradient(180deg, #fdfaf4 0%, var(--bg-base) 100%);
        }

        .bg-shape {
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image:
                linear-gradient(130deg, rgba(0, 127, 127, 0.045) 25%, transparent 25%),
                linear-gradient(310deg, rgba(239, 111, 60, 0.04) 25%, transparent 25%);
            background-size: 36px 36px;
            mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.65), transparent 88%);
            z-index: 0;
        }

        .site-wrap {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .navbar {
            margin: 1rem auto 0;
            width: min(1120px, calc(100% - 1.5rem));
            border: 1px solid rgba(255, 255, 255, 0.6);
            border-radius: 18px;
            background: rgba(255, 253, 248, 0.82);
            backdrop-filter: blur(8px);
            box-shadow: var(--shadow-nav);
        }

        .navbar-brand {
            font-family: 'DM Serif Display', serif;
            font-size: 1.45rem;
            color: var(--brand-deep) !important;
            letter-spacing: 0.5px;
        }

        .nav-link {
            font-weight: 500;
            color: var(--text-soft) !important;
            border-radius: 9px;
            padding: 0.45rem 0.75rem !important;
            transition: all 0.2s ease;
        }

        .nav-link:hover {
            color: var(--brand-deep) !important;
            background-color: rgba(0, 127, 127, 0.08);
        }

        .btn-primary {
            border: none;
            border-radius: 10px;
            padding: 0.6rem 1rem;
            font-weight: 600;
            background: linear-gradient(135deg, var(--brand) 0%, #009f9f 100%);
            box-shadow: 0 8px 18px rgba(0, 127, 127, 0.25);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(0, 127, 127, 0.3);
        }

        .btn-outline-brand {
            border: 1px solid var(--brand);
            color: var(--brand);
            border-radius: 10px;
            font-weight: 600;
        }

        .btn-outline-brand:hover {
            background-color: var(--brand);
            border-color: var(--brand);
            color: #fff;
        }

        .card {
            border: 1px solid rgba(0, 127, 127, 0.1);
            border-radius: 18px;
            box-shadow: var(--shadow-soft);
            background: var(--bg-surface);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 38px rgba(37, 50, 56, 0.14);
        }

        .content-shell {
            width: min(1120px, calc(100% - 1.5rem));
            margin: 1.4rem auto 0;
            animation: reveal 0.45s ease;
        }

        .page-title {
            font-family: 'DM Serif Display', serif;
            font-size: clamp(1.7rem, 2.8vw, 2.3rem);
            margin-bottom: 0.2rem;
        }

        .muted {
            color: var(--text-soft);
        }

        .status-chip {
            border-radius: 999px;
            padding: 0.25rem 0.65rem;
            font-size: 0.75rem;
            font-weight: 600;
            border: 1px solid transparent;
            display: inline-flex;
            align-items: center;
        }

        .status-pendiente {
            background-color: #f7ebd5;
            border-color: #f4d7a8;
            color: #8d5d1d;
        }

        .status-confirmada {
            background-color: #dff3f3;
            border-color: #b6e3e3;
            color: #0f6464;
        }

        .status-completada {
            background-color: #e2f3df;
            border-color: #c0e3ba;
            color: #2a6632;
        }

        .status-cancelada {
            background-color: #f9e1df;
            border-color: #efc0bb;
            color: #9f3830;
        }

        .status-default {
            background-color: #edf1f2;
            border-color: #d5dee0;
            color: #49616a;
        }

        .form-control,
        .form-select {
            border-radius: 10px;
            border: 1px solid #cdd8d6;
            padding: 0.68rem 0.8rem;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: rgba(0, 127, 127, 0.65);
            box-shadow: 0 0 0 0.2rem rgba(0, 127, 127, 0.15);
        }

        .footer {
            margin-top: auto;
            padding: 1.6rem 0 1.9rem;
            text-align: center;
            color: var(--text-soft);
            font-size: 0.9rem;
        }

        .footer strong {
            color: var(--brand-deep);
            font-weight: 600;
        }

        @keyframes reveal {
            from {
                opacity: 0;
                transform: translateY(14px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media (max-width: 991px) {
            .navbar {
                border-radius: 14px;
                margin-top: 0.7rem;
            }
        }

        @media (max-width: 576px) {
            .content-shell,
            .navbar {
                width: calc(100% - 1rem);
            }

            .navbar-brand {
                font-size: 1.25rem;
            }
        }
    </style>
</head>
<body>
    <div class="bg-shape"></div>
    <div class="site-wrap">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container">
                <a class="navbar-brand" href="/">Veterinaria App</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" href="/">Inicio</a>
                        </li>
                        <% if (user && (user.role === 'veterinario' || user.role === 'admin')) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/create">Agendar Cita</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/medical-history">Historial Clinico</a>
                        </li>
                        <% } %>
                        <% if (user) { %>
                        <li class="nav-item ms-2 me-2">
                            <span class="badge rounded-pill border" style="font-size: .75rem; background:#fff; color:#385157; border-color:#d5e1df !important;">
                                <%= user.full_name %> | <%= user.role %>
                            </span>
                        </li>
                        <li class="nav-item">
                            <form action="/logout" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-outline-brand btn-sm">Cerrar sesion</button>
                            </form>
                        </li>
                        <% } else { %>
                        <li class="nav-item ms-2">
                            <a class="btn btn-primary btn-sm" href="/login">Iniciar Sesion</a>
                        </li>
                        <% } %>
                    </ul>
                </div>
            </div>
        </nav>

        <main class="content-shell">
            <%- body %>
        </main>

        <footer class="footer">
            <div class="content-shell" style="margin-top: 0;">
                <p>&copy; 2026 <strong>Veterinaria App</strong> | Gestion de citas y pacientes</p>
            </div>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
