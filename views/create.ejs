<section class="mb-4">
    <div class="card border-0" style="background: linear-gradient(132deg, rgba(0,127,127,0.16), rgba(239,111,60,0.18));">
        <div class="card-body p-4 p-md-5 d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center">
            <div>
                <p class="text-uppercase fw-semibold mb-2" style="font-size: .74rem; letter-spacing: .08em; color: #0f6464;">Nuevo registro</p>
                <h1 class="page-title mb-1">Agendar Nueva Cita</h1>
                <p class="muted mb-0">Completa la informacion para programar el servicio.</p>
            </div>
            <a href="/" class="btn btn-outline-brand">Volver al panel</a>
        </div>
    </div>
</section>

<section class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body p-4 p-md-5">
                <form action="/create" method="POST" class="row g-3">
                    <div class="col-12">
                        <label for="pet_id" class="form-label fw-semibold">Mascota</label>
                        <select id="pet_id" name="pet_id" class="form-select" required>
                            <option value="" selected disabled>Selecciona una mascota</option>
                            <% pets.forEach(pet => { %>
                                <option value="<%= pet.id %>"><%= pet.name %> - <%= pet.breed %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="col-md-7">
                        <label for="service" class="form-label fw-semibold">Servicio</label>
                        <input
                            type="text"
                            id="service"
                            name="service"
                            class="form-control"
                            placeholder="Ejemplo: Bano y corte"
                            list="service-options"
                            required
                        >
                        <datalist id="service-options">
                            <option value="Bano y corte"></option>
                            <option value="Consulta general"></option>
                            <option value="Vacunacion"></option>
                            <option value="Control postoperatorio"></option>
                        </datalist>
                    </div>

                    <div class="col-md-5">
                        <label for="appointment_date" class="form-label fw-semibold">Fecha y hora</label>
                        <input
                            type="datetime-local"
                            id="appointment_date"
                            name="appointment_date"
                            class="form-control"
                            required
                        >
                    </div>

                    <div class="col-md-6">
                        <label for="diagnosis" class="form-label fw-semibold">Diagnostico</label>
                        <input
                            type="text"
                            id="diagnosis"
                            name="diagnosis"
                            class="form-control"
                            placeholder="Ejemplo: Gastroenteritis leve"
                            required
                        >
                    </div>

                    <div class="col-md-3">
                        <label for="weight" class="form-label fw-semibold">Peso (kg)</label>
                        <input
                            type="number"
                            id="weight"
                            name="weight"
                            class="form-control"
                            placeholder="0.0"
                            min="0"
                            step="0.1"
                            required
                        >
                    </div>

                    <div class="col-md-3">
                        <label for="prescribed_medication" class="form-label fw-semibold">Medicina recetada</label>
                        <input
                            type="text"
                            id="prescribed_medication"
                            name="prescribed_medication"
                            class="form-control"
                            placeholder="Ejemplo: Amoxicilina"
                            required
                        >
                    </div>

                    <div class="col-12 d-flex flex-column flex-sm-row gap-2 pt-2">
                        <button type="submit" class="btn btn-primary">Guardar cita</button>
                        <a href="/" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
