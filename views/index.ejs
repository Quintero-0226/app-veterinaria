<section class="mb-4">
    <div class="card border-0" style="background: linear-gradient(130deg, rgba(0,127,127,0.14), rgba(239,111,60,0.18));">
        <div class="card-body p-4 p-md-5">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <p class="text-uppercase fw-semibold mb-2" style="font-size: .74rem; letter-spacing: .08em; color: #0f6464;">Agenda clinica</p>
                    <h1 class="page-title mb-1">Panel de Citas</h1>
                    <p class="muted mb-0">Visualiza, organiza y gestiona las atenciones diarias.</p>
                </div>
                <% if (user && (user.role === 'veterinario' || user.role === 'admin')) { %>
                <a href="/create" class="btn btn-primary">Nueva Cita</a>
                <% } %>
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <p class="muted mb-1" style="font-size:.85rem;">Total citas</p>
                    <h2 class="mb-0" style="font-family:'DM Serif Display', serif;"><%= appointments.length %></h2>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center">
                    <p class="mb-0 muted">Mantener la agenda al dia evita cruces de horario y mejora la atencion al paciente.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section>
    <div class="row">
        <% if (appointments.length === 0) { %>
            <div class="col-12">
                <div class="card text-center p-5">
                    <h3 class="page-title" style="font-size:1.7rem;">No hay citas registradas</h3>
                    <p class="muted mb-4">Inicia la jornada creando la primera cita del dia.</p>
                    <% if (user && (user.role === 'veterinario' || user.role === 'admin')) { %>
                    <div>
                        <a href="/create" class="btn btn-primary">Crear cita</a>
                    </div>
                    <% } %>
                </div>
            </div>
        <% } else { %>
            <% appointments.forEach(app => { %>
                <%
                    const rawStatus = (app.status || 'pendiente').toLowerCase();
                    const statusClass = ['pendiente', 'confirmada', 'completada', 'cancelada'].includes(rawStatus)
                        ? 'status-' + rawStatus
                        : 'status-default';
                %>
                <div class="col-md-6 col-xl-4 mb-4">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                                <h5 class="mb-0" style="font-weight:700; color:#0d5353;"><%= app.pet_name %></h5>
                                <span class="status-chip <%= statusClass %>"><%= app.status || 'pendiente' %></span>
                            </div>

                            <div class="mb-3">
                                <p class="mb-1"><strong>Dueno:</strong> <%= app.owner_name %></p>
                                <p class="mb-1"><strong>Servicio:</strong> <%= app.service %></p>
                                <p class="mb-0"><strong>Fecha:</strong> <%= app.appointment_date %></p>
                            </div>

                            <div class="mt-auto pt-2">
                                <% if (user) { %>
                                <form action="/delete/<%= app.id %>" method="POST" onsubmit="return confirm('¿Eliminar esta cita?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                                </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</section>
