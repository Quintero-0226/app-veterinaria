<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="card p-4 shadow-sm">
            <div class="text-center mb-4">
                <span style="font-size:2.5rem;">🐾</span>
                <h4 class="fw-semibold mt-2" style="color:#6c5ce7;">PeluCan Spa</h4>
                <p class="text-muted small">Acceso al sistema de gestión</p>
            </div>

            <% if (error) { %>
                <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
                    <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <form action="/login" method="POST">
                <div class="mb-3">
                    <label for="username" class="form-label fw-semibold">Usuario</label>
                    <input type="text" class="form-control" id="username" name="username"
                           placeholder="Ingresa tu usuario" required autofocus>
                </div>
                <div class="mb-4">
                    <label for="password" class="form-label fw-semibold">Contraseña</label>
                    <input type="password" class="form-control" id="password" name="password"
                           placeholder="••••••••" required>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Iniciar Sesión</button>
                </div>
            </form>

            <hr class="my-4">
            <p class="text-muted small text-center mb-1"><strong>Usuarios de prueba:</strong></p>
            <table class="table table-sm table-borderless text-muted small">
                <tbody>
                    <tr><td><code>admin</code></td><td><code>admin123</code></td><td>Administrador</td></tr>
                    <tr><td><code>dr_garcia</code></td><td><code>vet123</code></td><td>Veterinario</td></tr>
                    <tr><td><code>recepcion</code></td><td><code>rec123</code></td><td>Recepcionista</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
