<section class="row justify-content-center align-items-stretch g-4">
    <div class="col-lg-10">
        <div class="card overflow-hidden">
            <div class="row g-0">
                <div class="col-md-5 p-4 p-md-5 d-flex flex-column justify-content-between" style="background: linear-gradient(155deg, rgba(0,127,127,0.95), rgba(0,94,94,0.96)); color: #f2faf9;">
                    <div>
                        <p class="text-uppercase fw-semibold mb-2" style="font-size: .74rem; letter-spacing: .1em; opacity: .9;">Acceso seguro</p>
                        <h1 style="font-family:'DM Serif Display', serif; font-size:2.1rem; line-height:1.15;">Bienvenido al panel clinico</h1>
                        <p class="mb-0" style="opacity:.9;">Inicia sesion para administrar citas y pacientes.</p>
                    </div>
                    <div class="mt-4 pt-3 border-top" style="border-color: rgba(255,255,255,0.25) !important;">
                        <p class="mb-2 fw-semibold" style="font-size:.9rem;">Usuarios de prueba</p>
                        <div class="small" style="opacity:.95;">
                            <div>admin / admin123</div>
                            <div>dr_garcia / vet123</div>
                            <div>recepcion / rec123</div>
                        </div>
                    </div>
                </div>

                <div class="col-md-7 p-4 p-md-5">
                    <h2 class="page-title mb-1" style="font-size:1.9rem;">Iniciar Sesion</h2>
                    <p class="muted mb-4">Usa tus credenciales para continuar.</p>

                    <% if (error) { %>
                        <div class="alert alert-danger py-2" role="alert">
                            <%= error %>
                        </div>
                    <% } %>

                    <form action="/login" method="POST">
                        <div class="mb-3">
                            <label for="username" class="form-label fw-semibold">Usuario</label>
                            <input type="text" class="form-control" id="username" name="username" placeholder="Ingresa tu usuario" required autofocus>
                        </div>
                        <div class="mb-4">
                            <label for="password" class="form-label fw-semibold">Contrasena</label>
                            <input type="password" class="form-control" id="password" name="password" placeholder="Ingresa tu contrasena" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Entrar</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
